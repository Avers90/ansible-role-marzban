{
  "log": {
    "loglevel": "{{ marzban_xray_log_level }}"
  },
  "inbounds": [
    {
      "tag": "VLESS_XHTTP",
      "listen": "127.0.0.1",
      "port": {{ marzban_xhttp_port }},
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "path": "{{ marzban_xhttp_path }}",
          "host": "{{ marzban_domain }}"
        }
      },
      "sniffing": {
        "enabled": {{ marzban_xray_sniffing_enabled | lower }},
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }{% for inbound in marzban_xray_extra_inbounds %},
    {{ inbound | to_json(indent=4) | indent(4) }}{% endfor %}
  ],
  "outbounds": [
    {
      "tag": "DIRECT",
      "protocol": "freedom"
    },
    {
      "tag": "BLACKHOLE",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "rules": [
{% if marzban_xray_block_private_ip | bool %}
      {
        "type": "field",
        "ip": [
          "0.0.0.0/8",
          "10.0.0.0/8",
          "100.64.0.0/10",
          "127.0.0.0/8",
          "169.254.0.0/16",
          "172.16.0.0/12",
          "192.0.0.0/24",
          "192.168.0.0/16",
          "198.18.0.0/15",
          "198.51.100.0/24",
          "203.0.113.0/24",
          "::1/128",
          "fc00::/7",
          "fe80::/10"
        ],
        "outboundTag": "BLACKHOLE"
      }
{% endif %}
    ]
  }
}
