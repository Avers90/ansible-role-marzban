# {{ ansible_managed }}
# Marzban environment configuration
# Documentation: https://github.com/Gozargah/Marzban

## Marzban panel settings
UVICORN_HOST="127.0.0.1"
UVICORN_PORT="{{ marzban_panel_port }}"

## Admin dashboard path
DASHBOARD_PATH="{{ marzban_dashboard_path }}"

## SQLite database path
SQLALCHEMY_DATABASE_URL="sqlite:///{{ marzban_data_dir }}/db.sqlite3"

## Xray binary path (installed via Xray-install script)
XRAY_EXECUTABLE_PATH="/usr/local/bin/xray"

## Custom xray config (VLESS TLS + fallback to nginx)
XRAY_JSON="{{ marzban_data_dir }}/xray_config.json"

## Subscription URL prefix
XRAY_SUBSCRIPTION_URL_PREFIX="https://{{ marzban_domain }}"
