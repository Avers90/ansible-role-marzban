# {{ ansible_managed }}
# Marzban environment configuration
# Documentation: https://github.com/Gozargah/Marzban

## Marzban panel settings
UVICORN_HOST="{{ marzban_uvicorn_host }}"
UVICORN_PORT="{{ marzban_panel_port }}"

## Admin dashboard path
DASHBOARD_PATH="/dashboard/"

## SQLite database path
SQLALCHEMY_DATABASE_URL="sqlite:////var/lib/marzban/db.sqlite3"

## Custom xray config (VLESS TLS + fallback to nginx)
XRAY_JSON="/var/lib/marzban/xray_config.json"

## TLS certificate paths (issued by acme.sh)
XRAY_SUBSCRIPTION_URL_PREFIX="https://{{ marzban_domain }}"
