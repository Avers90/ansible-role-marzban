# {{ ansible_managed }}
[Unit]
Description=Marzban VPN Panel
Documentation=https://github.com/Gozargah/Marzban
After=network.target nss-lookup.target

[Service]
User=root
WorkingDirectory={{ marzban_install_dir }}
ExecStart={{ marzban_venv_dir }}/bin/python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
